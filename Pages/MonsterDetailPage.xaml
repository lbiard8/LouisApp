<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LouisApp.ViewModels"
             x:Class="LouisApp.Pages.MonsterDetailPage"
             x:DataType="vm:MonsterItemViewModel"
             Title="Fiche du Monstre"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="{Binding Monster.Name}" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="#D4AF37" 
                   HorizontalOptions="Center" />

            <Image Source="{Binding MonsterImage}" 
                   WidthRequest="200" 
                   HeightRequest="200" 
                   Aspect="AspectFit" 
                   HorizontalOptions="Center" />

            <Label Text="{Binding Monster.Type}" 
                   FontSize="18" 
                   TextColor="Gray" 
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="2" 
                     Color="#D4AF37" 
                     Margin="0,10" />

            <Label Text="Description" 
                   FontSize="22" 
                   TextColor="#D4AF37" 
                   FontAttributes="Bold" />

            <Label Text="{Binding Monster.Description}" 
                   FontSize="16" 
                   TextColor="White" 
                   LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>